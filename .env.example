# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── Auth.js ──────────────────────────────────────────────────────────────────
# Secret used to sign/encrypt JWTs and cookies.
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"

# Public URL of the deployed app (must match OAuth redirect URI)
AUTH_URL="https://your-app.example.com"

# Google OAuth credentials (from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Shared secret protecting the /api/cron/notify endpoint.
# Used by both the Vercel cron scheduler and the Railway cron-notify.sh script.
# Generate with: openssl rand -base64 32
# REQUIRED — the endpoint returns 401 if this is not set.
CRON_SECRET="replace-with-a-strong-random-secret"

# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the app (used for calendar links embedded in Slack messages)
NEXT_PUBLIC_BASE_URL="https://your-app.example.com"
